services:
  jellyfin:
    image: jellyfin/jellyfin
    container_name: jellyfin
    ports:
      - 8096:8096/tcp
      - 7359:7359/udp
    environment:
      - PUID=1000
      - PGID=1000
    volumes:
      - /opt/jellyfin/config:/config
      - /opt/jellyfin/cache:/cache
      - type: bind
        source: {{ jellyfin_path }}
        target: /media
        read_only: true
    restart: 'unless-stopped'